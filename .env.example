# Backend AI guide. Keep the real key only in .env.local or server env vars.
AI_API_KEY="MY_AI_API_KEY"
AI_MODEL_ID="astron-code-latest"
AI_OPENAI_URL="https://maas-coding-api.cn-huabei-1.xf-yun.com/v2"
AI_ANTHROPIC_URL="https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AMAP: Required for Gaode/AMap JavaScript API map pages.
# Create a Web JSAPI key in the AMap console, then put the values in .env.local.
VITE_AMAP_KEY="MY_AMAP_JSAPI_KEY"
VITE_AMAP_SECURITY_JS_CODE="MY_AMAP_SECURITY_JS_CODE"

# Optional when the frontend is hosted separately, for example GitHub Pages.
VITE_API_BASE_URL=""
